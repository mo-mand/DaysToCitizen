# JWT secret — change this to a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Resend API key for sending OTP emails (https://resend.com)
# Leave empty in development — OTPs will be logged to the console instead
RESEND_API_KEY=

# The "from" address for OTP emails (must be a verified domain in Resend)
EMAIL_FROM=noreply@daystocitizen.ca

# App URL (used in email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
